rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // User profile
    match /users/{uid} {
      allow read, write: if isAuth() && isOwner(uid);
    }

    // Tabs (Personal, People, Vault, Custom)
    match /tabs/{tabId} {
      allow read: if isAuth() && isOwner(resource.data.userId);
      allow create: if isAuth() && isOwner(request.resource.data.userId)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;
      allow update: if isAuth() && isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId; // FIXED: SEC-3
      allow delete: if isAuth() && isOwner(resource.data.userId);
    }

    // Windows / Pages within tabs
    match /windows/{windowId} {
      allow read: if isAuth() && isOwner(resource.data.userId);
      allow create: if isAuth() && isOwner(request.resource.data.userId)
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0;
      allow update: if isAuth() && isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId; // FIXED: SEC-3
      allow delete: if isAuth() && isOwner(resource.data.userId);
    }

    // Entries within windows
    match /entries/{entryId} {
      allow read: if isAuth() && isOwner(resource.data.userId);
      allow create: if isAuth() && isOwner(request.resource.data.userId)
        && request.resource.data.rawText is string
        && request.resource.data.rawText.size() > 0
        && request.resource.data.rawText.size() <= 500; // FIXED: SEC-4
      allow update: if isAuth() && isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.rawText is string
        && request.resource.data.rawText.size() > 0
        && request.resource.data.rawText.size() <= 500; // FIXED: SEC-3
      allow delete: if isAuth() && isOwner(resource.data.userId);
    }

    // People (person ledger headers)
    match /persons/{personId} {
      allow read: if isAuth() && isOwner(resource.data.userId);
      allow create: if isAuth() && isOwner(request.resource.data.userId)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;
      allow update: if isAuth() && isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId; // FIXED: SEC-3
      allow delete: if isAuth() && isOwner(resource.data.userId);
    }

    // Person ledger entries
    match /personEntries/{entryId} {
      allow read: if isAuth() && isOwner(resource.data.userId);
      allow create: if isAuth() && isOwner(request.resource.data.userId)
        && request.resource.data.rawText is string
        && request.resource.data.rawText.size() > 0
        && request.resource.data.rawText.size() <= 500; // FIXED: SEC-4
      allow update: if isAuth() && isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.rawText is string
        && request.resource.data.rawText.size() > 0
        && request.resource.data.rawText.size() <= 500; // FIXED: SEC-3
      allow delete: if isAuth() && isOwner(resource.data.userId);
    }

    // Vault items
    match /vault/{itemId} {
      allow read: if isAuth() && isOwner(resource.data.userId);
      allow create: if isAuth() && isOwner(request.resource.data.userId)
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0;
      allow update: if isAuth() && isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId; // FIXED: SEC-3
      allow delete: if isAuth() && isOwner(resource.data.userId);
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
